# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://peoplehub:peoplehub_secret@localhost:5432/peoplehub_os?schema=public"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (NextAuth.js) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-here

# ─── OAuth Providers ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── File Storage (S3-compatible) ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=minio_access_key
S3_SECRET_ACCESS_KEY=minio_secret_key
S3_BUCKET_NAME=peoplehub-files

# ─── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="PeopleHub OS <noreply@peoplehub.io>"

# ─── API Gateway ───────────────────────────────────────────────────────────────
API_SECRET_KEY=your-internal-api-secret-key-here
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret-here

# ─── AI (Claude) ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# SENTRY_DSN=
