NODE_ENV=production

# Public URL. Use http://167.233.137.16 for IP-only launch, then replace with your domain.
APP_URL=http://167.233.137.16
API_URL=http://api:3001
NEXTAUTH_URL=http://167.233.137.16
NEXT_PUBLIC_API_URL=/api/v1

POSTGRES_USER=peoplehub
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=peoplehub_os
DATABASE_URL=postgresql://peoplehub:replace-with-a-long-random-postgres-password@postgres:5432/peoplehub_os?schema=public

REDIS_URL=redis://redis:6379

NEXTAUTH_SECRET=replace-with-a-min-32-char-nextauth-secret
JWT_SECRET=replace-with-a-min-32-char-jwt-secret
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-a-min-32-char-encryption-key
API_SECRET_KEY=replace-with-a-long-random-internal-api-key
WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-webhook-secret

S3_ENDPOINT=http://minio:9000
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=replace-with-minio-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-secret
S3_BUCKET_NAME=peoplehub-files

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="PeopleHub OS <noreply@example.com>"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
ANTHROPIC_API_KEY=
LOG_LEVEL=info
