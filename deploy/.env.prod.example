# Public domain
PUBLIC_HOST=viohr.triviontechnologies.com
APP_URL=https://viohr.triviontechnologies.com
NEXTAUTH_URL=https://viohr.triviontechnologies.com
NEXT_PUBLIC_APP_URL=https://viohr.triviontechnologies.com
NEXT_PUBLIC_API_URL=/api/v1

# Database
POSTGRES_USER=viohr
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=viohr

# Auth and API secrets
NEXTAUTH_SECRET=replace-with-at-least-32-random-characters
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Redis and storage
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=viohr-minio
S3_SECRET_ACCESS_KEY=replace-with-a-strong-minio-secret
S3_BUCKET_NAME=viohr-files

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="VioHr <noreply@example.com>"
# Platform transactional email fallback. Tenant SMTP overrides this when active.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=VioHr
RESEND_REPLY_TO=

# API Gateway
API_SECRET_KEY=replace-with-internal-api-secret
WEBHOOK_SIGNING_SECRET=replace-with-webhook-signing-secret

# AI
ANTHROPIC_API_KEY=

# Observability
LOG_LEVEL=info
