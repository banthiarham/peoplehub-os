generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum EmployeeStatus {
  CANDIDATE
  PREBOARDING
  ACTIVE
  ON_PROBATION
  CONFIRMED
  ON_NOTICE
  EXITED
  ABSCONDING
  CONTRACTOR
  INTERN
  INACTIVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
  CONSULTANT
}

enum WorkMode {
  OFFICE
  REMOTE
  HYBRID
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum TaxRegime {
  OLD
  NEW
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  WEEKEND
  LATE
  EARLY_LEAVING
  MISSING_PUNCH
  COMP_OFF
}

enum ShiftType {
  FIXED
  ROTATIONAL
  FLEXIBLE
  NIGHT
  SPLIT
}

enum RosterUploadStatus {
  DRAFT
  IMPORTED
  FAILED
}

enum ShiftSwapStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum CompOffStatus {
  AVAILABLE
  USED
  EXPIRED
  CANCELLED
}

enum AttendanceFinalizationStatus {
  FINALIZED
  REOPENED
}

enum AttendanceCaptureMode {
  WEB
  MOBILE
  GPS
  QR
  BIOMETRIC
  MANUAL
  API_IMPORT
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  REVIEW
  APPROVED
  LOCKED
  PUBLISHED
  CLOSED
}

enum PayrollRunType {
  MONTHLY
  OFF_CYCLE
  FULL_AND_FINAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  WITHDRAWN
  EXPIRED
}

enum CandidateStage {
  APPLIED
  SCREENING
  RECRUITER_CALL
  TECHNICAL_ROUND
  MANAGER_ROUND
  HR_ROUND
  OFFER_APPROVAL
  OFFER_SENT
  OFFER_ACCEPTED
  JOINED
  REJECTED
  ON_HOLD
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  CLARIFICATION_REQUESTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseReimbursementMethod {
  PAYROLL
  DIRECT
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  WRITTEN_OFF
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum NotificationTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  SLACK
  TEAMS
  PUSH
}

enum PermissionType {
  VIEW
  CREATE
  EDIT
  DELETE
  APPROVE
  EXPORT
  IMPORT
  CONFIGURE
  RUN_PAYROLL
  LOCK_PAYROLL
  UNLOCK_PAYROLL
  VIEW_SENSITIVE
  MANAGE_INTEGRATIONS
  MANAGE_API_KEYS
}

enum ScopeType {
  OWN_DATA
  DIRECT_REPORTS
  DEPARTMENT
  LOCATION
  LEGAL_ENTITY
  ENTIRE_TENANT
  CUSTOM_GROUP
}

// ─── Module 1: Organization & Tenant ───────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  name        String
  legalName   String?
  slug        String       @unique
  country     String       @default("IN")
  industry    String?
  companySize String?
  billingPlan String       @default("trial")
  status      TenantStatus @default(TRIAL)
  timezone    String       @default("Asia/Kolkata")
  currency    String       @default("INR")
  logoUrl     String?
  brandColor  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  legalEntities             LegalEntity[]
  locations                 Location[]
  departments               Department[]
  designations              Designation[]
  costCenters               CostCenter[]
  businessUnits             BusinessUnit[]
  users                     User[]
  roles                     Role[]
  employees                 Employee[]
  shifts                    Shift[]
  attendanceRules           AttendanceRule[]
  attendanceCaptureSettings AttendanceCaptureSetting[]
  rosterUploads             RosterUpload[]
  attendanceFinalizations   AttendanceFinalization[]
  compOffGrants             CompOffGrant[]
  shiftSwapRequests         ShiftSwapRequest[]
  holidayCalendars          HolidayCalendar[]
  leaveTypes                LeaveType[]
  leavePolicies             LeavePolicy[]
  salaryStructures          SalaryStructure[]
  payrollRuns               PayrollRun[]
  workflows                 Workflow[]
  notifications             Notification[]
  notificationTemplates     NotificationTemplate[]
  documentTemplates         DocumentTemplate[]
  generatedDocuments        GeneratedDocument[]
  policyAcknowledgements    PolicyAcknowledgement[]
  apiKeys                   ApiKey[]
  apiRequestLogs            ApiRequestLog[]
  oauthClients              OAuthClient[]
  webhookSubscriptions      WebhookSubscription[]
  integrationConnections    IntegrationConnection[]
  auditLogs                 AuditLog[]
  approvalRequestHistory    ApprovalRequestHistory[]
  customFields              CustomField[]
  customForms               CustomForm[]
  surveys                   Survey[]
  announcements             Announcement[]
  jobRequisitions           JobRequisition[]
  onboardingTemplates       OnboardingTemplate[]
  assets                    Asset[]
  projects                  Project[]
  reviewCycles              ReviewCycle[]
  competencyFrameworks      CompetencyFramework[]
  anonymousFeedbacks        AnonymousFeedback[]
  helpdeskSlaRules          HelpdeskSlaRule[]
  knowledgeBaseArticles     KnowledgeBaseArticle[]
  assetDocuments            AssetDocument[]
  clients                   Client[]
  projectTasks              ProjectTask[]

  @@index([slug])
  @@map("tenants")
}

model LegalEntity {
  id                    String   @id @default(cuid())
  tenantId              String
  name                  String
  legalName             String?
  pan                   String?
  tan                   String?
  gstin                 String?
  pfRegistrationNumber  String?
  esiRegistrationNumber String?
  ptRegistrationNumber  String?
  address               String?
  city                  String?
  state                 String?
  country               String   @default("IN")
  payrollSettings       Json?
  bankDetails           Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([tenantId])
  @@map("legal_entities")
}

model Location {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  address          String?
  city             String?
  state            String?
  country          String   @default("IN")
  pincode          String?
  geoLat           Float?
  geoLng           Float?
  attendanceRadius Int? // meters
  timezone         String   @default("Asia/Kolkata")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees                 Employee[]
  holidayCalendars          HolidayCalendar[]
  attendanceRules           AttendanceRule[]
  attendanceCaptureSettings AttendanceCaptureSetting[]
  leavePolicies             LeavePolicy[]

  @@index([tenantId])
  @@map("locations")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  parentId  String?
  headId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Designation {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  grade     String?
  level     Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([tenantId])
  @@map("designations")
}

model CostCenter {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([tenantId])
  @@map("cost_centers")
}

model BusinessUnit {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([tenantId])
  @@map("business_units")
}

// ─── Module 3: Auth, Users, Roles & Permissions ─────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  name         String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  isSuperAdmin Boolean   @default(false)
  lastLoginAt  DateTime?
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee?
  userRoles     UserRole[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditLogActor")

  @@unique([tenantId, email])
  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  permissions Permission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id             String         @id @default(cuid())
  roleId         String
  module         String
  permissionType PermissionType
  scopeType      ScopeType      @default(OWN_DATA)
  scopeValue     String?

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, permissionType, scopeType])
  @@map("permissions")
}

// ─── Module 2: Core HR & Employee Master ────────────────────────────────────

model Employee {
  id               String         @id @default(cuid())
  tenantId         String
  userId           String?        @unique
  employeeCode     String
  firstName        String
  lastName         String
  preferredName    String?
  personalEmail    String?
  workEmail        String?
  phone            String?
  dateOfBirth      DateTime?
  gender           Gender?
  maritalStatus    MaritalStatus?
  bloodGroup       String?
  address          Json?
  emergencyContact Json?

  // Work info
  joiningDate      DateTime?
  confirmationDate DateTime?
  exitDate         DateTime?
  status           EmployeeStatus @default(PREBOARDING)
  employmentType   EmploymentType @default(FULL_TIME)
  workMode         WorkMode       @default(OFFICE)
  probationEndDate DateTime?
  noticePeriodDays Int?

  // Org structure
  tenantId2       String? // unused, just for future reference
  legalEntityId   String?
  departmentId    String?
  designationId   String?
  locationId      String?
  costCenterId    String?
  businessUnitId  String?
  managerId       String?
  dottedManagerId String?

  // India-specific
  pan        String?
  aadhaar    String? // store masked
  uan        String?
  esicNumber String?
  taxRegime  TaxRegime @default(NEW)

  // Bank
  bankDetails Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
  legalEntity   LegalEntity?  @relation(fields: [legalEntityId], references: [id])
  department    Department?   @relation(fields: [departmentId], references: [id])
  designation   Designation?  @relation(fields: [designationId], references: [id])
  location      Location?     @relation(fields: [locationId], references: [id])
  costCenter    CostCenter?   @relation(fields: [costCenterId], references: [id])
  businessUnit  BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  manager       Employee?     @relation("ManagerRelation", fields: [managerId], references: [id])
  directReports Employee[]    @relation("ManagerRelation")
  dottedManager Employee?     @relation("DottedManagerRelation", fields: [dottedManagerId], references: [id])
  dottedReports Employee[]    @relation("DottedManagerRelation")

  profileChanges           EmployeeProfileChange[]
  documents                EmployeeDocument[]
  generatedDocuments       GeneratedDocument[]
  policyAcknowledgements   PolicyAcknowledgement[]
  lifecycleEvents          EmployeeLifecycleEvent[]
  attendanceRecords        AttendanceRecord[]
  shiftAssignments         ShiftAssignment[]
  rosterUploads            RosterUpload[]
  requestedShiftSwaps      ShiftSwapRequest[]           @relation("ShiftSwapRequester")
  counterpartShiftSwaps    ShiftSwapRequest[]           @relation("ShiftSwapCounterpart")
  compOffGrants            CompOffGrant[]
  leaveBalances            LeaveBalance[]
  leaveRequests            LeaveRequest[]
  employeeSalaries         EmployeeSalary[]
  payrollRunEntries        PayrollRunEmployee[]
  payslips                 Payslip[]
  payrollInputs            PayrollVariableInput[]
  taxDeclarations          TaxDeclaration[]
  expenseClaims            ExpenseClaim[]
  loans                    Loan[]
  loanInstallments         LoanInstallment[]
  assetAssignments         AssetAssignment[]
  timesheets               Timesheet[]
  goals                    Goal[]
  reviewResponses          ReviewResponse[]
  performanceCheckIns      PerformanceCheckIn[]         @relation("CheckInEmployee")
  managerCheckIns          PerformanceCheckIn[]         @relation("CheckInManager")
  oneOnOnes                OneOnOne[]                   @relation("OneOnOneEmployee")
  managerOneOnOnes         OneOnOne[]                   @relation("OneOnOneManager")
  performanceCalibrations  PerformanceCalibration[]     @relation("CalibrationReviewee")
  performancePlans         PerformanceImprovementPlan[]
  promotionRecommendations PromotionRecommendation[]
  feedbacks                Feedback[]                   @relation("FeedbackRecipient")
  feedbacksGiven           Feedback[]                   @relation("FeedbackGiver")
  recognitions             Recognition[]                @relation("RecognitionRecipient")
  recognitionsGiven        Recognition[]                @relation("RecognitionGiver")
  tickets                  Ticket[]
  onboardingTasks          OnboardingTask[]             @relation("OnboardingEmployee")
  exitRequests             ExitRequest[]
  exitTasks                ExitTask[]                   @relation("ExitEmployee")
  approvalRequests         ApprovalRequest[]            @relation("ApprovalRequester")
  approvals                ApprovalRequest[]            @relation("ApprovalApprover")
  device                   EmployeeDevice?
  RosterUploadRow          RosterUploadRow[]
  AttendanceFinalization   AttendanceFinalization[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([managerId])
  @@map("employees")
}

// One registered punch device per employee. deviceId is also unique per
// tenant so a single phone can never punch for more than one employee.
model EmployeeDevice {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String   @unique
  deviceId     String
  deviceName   String?
  platform     String?
  registeredAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, deviceId])
  @@index([tenantId])
  @@map("employee_devices")
}

model EmployeeProfileChange {
  id           String    @id @default(cuid())
  employeeId   String
  fieldName    String
  oldValue     String?
  newValue     String?
  changedById  String?
  reason       String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_profile_changes")
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  tenantId     String
  type         String
  name         String
  fileKey      String
  fileUrl      String?
  mimeType     String?
  sizeBytes    Int?
  isVerified   Boolean   @default(false)
  expiresAt    DateTime?
  uploadedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tenantId])
  @@map("employee_documents")
}

model EmployeeLifecycleEvent {
  id            String   @id @default(cuid())
  employeeId    String
  eventType     String
  fromStatus    String?
  toStatus      String?
  effectiveDate DateTime
  remarks       String?
  createdById   String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_lifecycle_events")
}

// ─── Module 5: Attendance, Leave, Shifts ────────────────────────────────────

model Shift {
  id                    String    @id @default(cuid())
  tenantId              String
  name                  String
  type                  ShiftType @default(FIXED)
  startTime             String // "09:00"
  endTime               String // "18:00"
  gracePeriodMins       Int       @default(15)
  earlyLeavingGraceMins Int       @default(15)
  breakDurationMins     Int       @default(60)
  minWorkingMinutes     Int       @default(480)
  halfDayAfterMinutes   Int       @default(240)
  absentAfterMinutes    Int       @default(0)
  overtimeAfterMinutes  Int       @default(480)
  shiftAllowanceAmount  Float     @default(0)
  weeklyOffDays         Int[]     @default([0, 6]) // 0=Sun, 6=Sat
  remoteAllowed         Boolean   @default(false)
  weekendWorkAllowed    Boolean   @default(false)
  holidayWorkAllowed    Boolean   @default(false)
  compOffEligible       Boolean   @default(false)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendanceRules     AttendanceRule[]
  shiftAssignments    ShiftAssignment[]
  attendanceRecords   AttendanceRecord[]
  rosterRows          RosterUploadRow[]
  requestedShiftSwaps ShiftSwapRequest[] @relation("RequestedShift")
  targetShiftSwaps    ShiftSwapRequest[] @relation("TargetShift")

  @@index([tenantId])
  @@map("shifts")
}

model ShiftAssignment {
  id             String    @id @default(cuid())
  employeeId     String
  shiftId        String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  source         String    @default("MANUAL") // MANUAL, ROSTER_UPLOAD, SHIFT_SWAP
  rosterUploadId String?
  createdAt      DateTime  @default(now())

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift        Shift         @relation(fields: [shiftId], references: [id])
  rosterUpload RosterUpload? @relation(fields: [rosterUploadId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([shiftId])
  @@index([rosterUploadId])
  @@map("shift_assignments")
}

model AttendanceRule {
  id                      String    @id @default(cuid())
  tenantId                String
  name                    String
  shiftId                 String?
  locationId              String?
  effectiveFrom           DateTime  @default(now())
  effectiveTo             DateTime?
  gracePeriodMins         Int       @default(15)
  lateMarkAfterMins       Int       @default(15)
  earlyLeavingGraceMins   Int       @default(15)
  halfDayAfterMinutes     Int       @default(240)
  absentAfterMinutes      Int       @default(0)
  breakDurationMins       Int       @default(60)
  minWorkingMinutes       Int       @default(480)
  overtimeAfterMinutes    Int       @default(480)
  remoteAttendanceAllowed Boolean   @default(false)
  shiftToleranceMins      Int       @default(0)
  weekendWorkAllowed      Boolean   @default(false)
  holidayWorkAllowed      Boolean   @default(false)
  compOffEligible         Boolean   @default(false)
  isDefault               Boolean   @default(false)
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift    Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([shiftId])
  @@index([locationId])
  @@map("attendance_rules")
}

model AttendanceCaptureSetting {
  id               String                @id @default(cuid())
  tenantId         String
  locationId       String?
  mode             AttendanceCaptureMode
  enabled          Boolean               @default(true)
  requiresGps      Boolean               @default(false)
  requiresGeofence Boolean               @default(false)
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, mode])
  @@index([tenantId])
  @@index([locationId])
  @@map("attendance_capture_settings")
}

model RosterUpload {
  id            String             @id @default(cuid())
  tenantId      String
  name          String
  status        RosterUploadStatus @default(DRAFT)
  periodStart   DateTime           @db.Date
  periodEnd     DateTime           @db.Date
  uploadedById  String?
  importedCount Int                @default(0)
  failedCount   Int                @default(0)
  errors        Json?
  createdAt     DateTime           @default(now())

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy       Employee?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  rows             RosterUploadRow[]
  shiftAssignments ShiftAssignment[]

  @@index([tenantId])
  @@map("roster_uploads")
}

model RosterUploadRow {
  id             String   @id @default(cuid())
  rosterUploadId String
  employeeId     String?
  employeeCode   String
  shiftId        String?
  shiftName      String?
  date           DateTime @db.Date
  status         String   @default("IMPORTED") // IMPORTED, FAILED
  error          String?
  createdAt      DateTime @default(now())

  rosterUpload RosterUpload @relation(fields: [rosterUploadId], references: [id], onDelete: Cascade)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  shift        Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([rosterUploadId])
  @@index([employeeId])
  @@map("roster_upload_rows")
}

model HolidayCalendar {
  id         String   @id @default(cuid())
  tenantId   String
  locationId String?
  name       String
  year       Int
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])
  holidays Holiday[]

  @@index([tenantId])
  @@map("holiday_calendars")
}

model Holiday {
