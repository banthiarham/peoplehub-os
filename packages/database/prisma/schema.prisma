  label        String
  amount       Float
  taxable      Boolean  @default(true)
  status       String   @default("APPROVED") // DRAFT, SUBMITTED, APPROVED, REJECTED
  source       String   @default("MANUAL") // MANUAL, EXPENSE, ATTENDANCE, EXIT
  metadata     Json?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, month, year])
  @@index([employeeId])
  @@index([payrollRunId])
  @@map("payroll_variable_inputs")
}

model TaxDeclaration {
