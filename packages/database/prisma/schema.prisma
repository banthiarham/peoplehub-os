model WebhookSubscription {
  id          String   @id @default(cuid())
  tenantId    String
  url         String
  events      String[]
  secret      String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id                    String                @id @default(cuid())
  webhookSubscriptionId String
  eventType             String
  payload               Json
  status                WebhookDeliveryStatus @default(PENDING)
  attempts              Int                   @default(0)
  lastAttemptAt         DateTime?
  responseCode          Int?
  responseBody          String?
  nextRetryAt           DateTime?
  createdAt             DateTime              @default(now())

  webhookSubscription WebhookSubscription @relation(fields: [webhookSubscriptionId], references: [id], onDelete: Cascade)

  @@index([webhookSubscriptionId])
  @@map("webhook_deliveries")
}

model IntegrationConnection {
  id          String    @id @default(cuid())
  tenantId    String
  provider    String
  name        String
  config      Json?
  credentials Json?
  isActive    Boolean   @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("integration_connections")
}

// ─── Module 21: Security & Audit ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  actorEmail String?
  action     String
  objectType String
  objectId   String?
  oldValue   Json?
  newValue   Json?
  reason     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([objectType, objectId])
  @@map("audit_logs")
}

// ─── Module 19: Custom Fields & Forms ───────────────────────────────────────

model CustomField {
  id         String   @id @default(cuid())
  tenantId   String
  module     String
  name       String
  fieldKey   String
  fieldType  String // TEXT, NUMBER, DATE, SELECT, MULTISELECT, BOOLEAN
  options    Json?
  isRequired Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module, fieldKey])
  @@index([tenantId])
  @@map("custom_fields")
}

model CustomForm {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  fields      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("custom_forms")
}

// ─── Module 16: AI Interaction Logging ──────────────────────────────────────

model AIInteractionLog {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  assistantType String // EMPLOYEE, HR, PAYROLL, MANAGER, RECRUITER
  prompt        String
  response      String
  tokensUsed    Int?
  latencyMs     Int?
  model         String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@map("ai_interaction_logs")
}

// ─── File Storage ────────────────────────────────────────────────────────────

model FileObject {
  id              String   @id @default(cuid())
  tenantId        String
  key             String   @unique
  name            String
  mimeType        String?
  sizeBytes       Int?
  bucket          String
  isPublic        Boolean  @default(false)
  uploadedById    String?
  virusScanStatus String   @default("PENDING")
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@map("file_objects")
}

// ─── Tax Engine (Module 6A) ───────────────────────────────────────────────────

enum AgeCategory {
  BELOW_60
  SENIOR_60_80
  SUPER_SENIOR_80_PLUS
  CUSTOM
}

enum ResidentialStatus {
  RESIDENT
  NON_RESIDENT
  RNOR
}

enum TaxRuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TaxDeclarationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum TaxProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model TaxYear {
  id             String    @id @default(cuid())
  tenantId       String
  financialYear  String
  assessmentYear String
  country        String    @default("IN")
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean   @default(true)
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  slabs          TaxSlab[]
  surchargeRules TaxSurchargeRule[]
  rebateRules    TaxRebateRule[]
  cessRules      TaxCessRule[]
  deductionRules TaxDeductionRule[]
  exemptionRules TaxExemptionRule[]
  ruleVersions   TaxRuleVersion[]
  regimeConfigs  TaxRegimeConfig[]

  @@unique([tenantId, financialYear, country])
  @@index([tenantId])
  @@map("tax_years")
}

// TaxRegimeConfig stores per-year regime settings (note: TaxRegime enum already exists for OLD/NEW)
model TaxRegimeConfig {
  id                String    @id @default(cuid())
  tenantId          String
  taxYearId         String
  regime            TaxRegime
  name              String
  description       String?
  isDefault         Boolean   @default(false)
  employeeCanSelect Boolean   @default(true)
  selectionLockDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@unique([tenantId, taxYearId, regime])
  @@index([tenantId, taxYearId])
  @@map("tax_regime_configs")
}

model TaxSlab {
  id          String        @id @default(cuid())
  tenantId    String
  taxYearId   String
  regime      TaxRegime
  ageCategory AgeCategory
  minIncome   Decimal       @db.Decimal(15, 2)
  maxIncome   Decimal?      @db.Decimal(15, 2)
  taxRate     Decimal       @db.Decimal(5, 4)
  fixedTax    Decimal       @default(0) @db.Decimal(15, 2)
  sortOrder   Int
  status      TaxRuleStatus @default(PUBLISHED)
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@index([tenantId, taxYearId, regime, ageCategory])
  @@map("tax_slabs")
}

model TaxSurchargeRule {
  id                    String        @id @default(cuid())
  tenantId              String
  taxYearId             String
  regime                TaxRegime
  minIncome             Decimal       @db.Decimal(15, 2)
  maxIncome             Decimal?      @db.Decimal(15, 2)
  surchargeRate         Decimal       @db.Decimal(5, 4)
  marginalReliefEnabled Boolean       @default(true)
  status                TaxRuleStatus @default(PUBLISHED)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@index([tenantId, taxYearId, regime])
  @@map("tax_surcharge_rules")
}

model TaxRebateRule {
  id          String        @id @default(cuid())
  tenantId    String
  taxYearId   String
  regime      TaxRegime
  section     String        @default("87A")
  maxRebate   Decimal       @db.Decimal(15, 2)
  incomeLimit Decimal       @db.Decimal(15, 2)
  status      TaxRuleStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@unique([tenantId, taxYearId, regime, section])
  @@index([tenantId, taxYearId])
  @@map("tax_rebate_rules")
}

model TaxCessRule {
  id                    String        @id @default(cuid())
  tenantId              String
  taxYearId             String
  regime                TaxRegime?
  country               String        @default("IN")
  cessName              String        @default("Health and Education Cess")
  cessRate              Decimal       @db.Decimal(5, 4)
  applicableOnTax       Boolean       @default(true)
  applicableOnSurcharge Boolean       @default(true)
  status                TaxRuleStatus @default(PUBLISHED)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@index([tenantId, taxYearId])
  @@map("tax_cess_rules")
}

model TaxDeductionRule {
  id            String        @id @default(cuid())
  tenantId      String
  taxYearId     String
  regime        TaxRegime
  section       String
  name          String
  description   String?
  maxLimit      Decimal?      @db.Decimal(15, 2)
  isEnabled     Boolean       @default(true)
  requiresProof Boolean       @default(false)
  sortOrder     Int           @default(0)
  status        TaxRuleStatus @default(PUBLISHED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@unique([tenantId, taxYearId, regime, section])
  @@index([tenantId, taxYearId, regime])
  @@map("tax_deduction_rules")
}

model TaxExemptionRule {
  id                 String        @id @default(cuid())
  tenantId           String
  taxYearId          String
  regime             TaxRegime
  name               String
  description        String?
  maxLimit           Decimal?      @db.Decimal(15, 2)
  calculationFormula String?
  isEnabled          Boolean       @default(true)
  requiresProof      Boolean       @default(false)
  status             TaxRuleStatus @default(PUBLISHED)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@unique([tenantId, taxYearId, regime, name])
  @@index([tenantId, taxYearId, regime])
  @@map("tax_exemption_rules")
}

model EmployeeTaxProfile {
  id                    String            @id @default(cuid())
  tenantId              String
  employeeId            String            @unique
  taxYearId             String
  regime                TaxRegime         @default(NEW)
  ageCategory           AgeCategory       @default(BELOW_60)
  residentialStatus     ResidentialStatus @default(RESIDENT)
  panNumber             String?
  dateOfBirth           DateTime?
  regimeLockedAt        DateTime?
  regimeLockedById      String?
  declarationWindowOpen Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  declarations   EmployeeTaxDeclaration[]
  previousIncome EmployeePreviousEmployerIncome[]
  monthlyTds     EmployeeMonthlyTds[]

  @@index([tenantId, taxYearId])
  @@map("employee_tax_profiles")
}

model EmployeeTaxDeclaration {
  id             String               @id @default(cuid())
  tenantId       String
  employeeId     String
  taxProfileId   String
  taxYearId      String
  section        String
  declaredAmount Decimal              @db.Decimal(15, 2)
  approvedAmount Decimal?             @db.Decimal(15, 2)
  status         TaxDeclarationStatus @default(DRAFT)
  metadata       Json?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  reviewNote     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  taxProfile EmployeeTaxProfile @relation(fields: [taxProfileId], references: [id])
  proofs     EmployeeTaxProof[]

  @@index([tenantId, employeeId, taxYearId])
  @@map("employee_tax_declarations")
}

model EmployeeTaxProof {
  id            String         @id @default(cuid())
  tenantId      String
  declarationId String
  employeeId    String
  fileObjectId  String?
  documentType  String
  description   String?
  status        TaxProofStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  declaration EmployeeTaxDeclaration @relation(fields: [declarationId], references: [id])

  @@index([tenantId, employeeId])
  @@map("employee_tax_proofs")
}

model EmployeePreviousEmployerIncome {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  taxProfileId    String
  taxYearId       String
  employerName    String
  employerPan     String?
  grossSalary     Decimal  @db.Decimal(15, 2)
  taxableAmount   Decimal  @db.Decimal(15, 2)
  tdsDeducted     Decimal  @default(0) @db.Decimal(15, 2)
  pfContribution  Decimal  @default(0) @db.Decimal(15, 2)
  professionalTax Decimal  @default(0) @db.Decimal(15, 2)
  from12B         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  taxProfile EmployeeTaxProfile @relation(fields: [taxProfileId], references: [id])

  @@index([tenantId, employeeId, taxYearId])
  @@map("employee_previous_employer_income")
}

model EmployeeMonthlyTds {
  id                    String   @id @default(cuid())
  tenantId              String
  employeeId            String
  taxProfileId          String
  taxYearId             String
  payrollRunId          String?
  month                 Int
  year                  Int
  grossIncomeTillDate   Decimal  @db.Decimal(15, 2)
  projectedAnnualIncome Decimal  @db.Decimal(15, 2)
  totalExemptions       Decimal  @default(0) @db.Decimal(15, 2)
  totalDeductions       Decimal  @default(0) @db.Decimal(15, 2)
  netTaxableIncome      Decimal  @db.Decimal(15, 2)
  taxBeforeRebate       Decimal  @db.Decimal(15, 2)
  rebate                Decimal  @default(0) @db.Decimal(15, 2)
  surcharge             Decimal  @default(0) @db.Decimal(15, 2)
  cess                  Decimal  @default(0) @db.Decimal(15, 2)
  totalTax              Decimal  @db.Decimal(15, 2)
  tdsDeductedTillDate   Decimal  @default(0) @db.Decimal(15, 2)
  remainingTax          Decimal  @db.Decimal(15, 2)
  remainingMonths       Int
  monthlyTds            Decimal  @db.Decimal(15, 2)
  effectiveTaxRate      Decimal  @db.Decimal(6, 4)
  createdAt             DateTime @default(now())

  taxProfile EmployeeTaxProfile @relation(fields: [taxProfileId], references: [id])

  @@unique([tenantId, employeeId, taxYearId, month, year])
  @@index([tenantId, employeeId, taxYearId])
  @@map("employee_monthly_tds")
}

model TaxComputationSnapshot {
  id                 String      @id @default(cuid())
  tenantId           String
  employeeId         String
  payrollRunId       String
  taxYearId          String
  regime             TaxRegime
  ageCategory        AgeCategory
  annualFixedSalary  Decimal     @db.Decimal(15, 2)
  grossTaxableIncome Decimal     @db.Decimal(15, 2)
  exemptIncome       Decimal     @default(0) @db.Decimal(15, 2)
  deductibleAmount   Decimal     @default(0) @db.Decimal(15, 2)
  netTaxableIncome   Decimal     @db.Decimal(15, 2)
  taxBeforeRebate    Decimal     @db.Decimal(15, 2)
  rebate             Decimal     @default(0) @db.Decimal(15, 2)
  surcharge          Decimal     @default(0) @db.Decimal(15, 2)
  cess               Decimal     @default(0) @db.Decimal(15, 2)
  totalAnnualTax     Decimal     @db.Decimal(15, 2)
  tdsAlreadyDeducted Decimal     @default(0) @db.Decimal(15, 2)
  remainingTax       Decimal     @db.Decimal(15, 2)
  monthlyTdsDeducted Decimal     @db.Decimal(15, 2)
  effectiveTaxRate   Decimal     @db.Decimal(6, 4)
  breakdownJson      Json
  slabsUsed          Json
  createdAt          DateTime    @default(now())

  @@index([tenantId, employeeId, payrollRunId])
  @@index([tenantId, payrollRunId])
  @@map("tax_computation_snapshots")
}

model TaxRuleVersion {
  id           String   @id @default(cuid())
  tenantId     String
  taxYearId    String
  entityType   String
  entityId     String
  version      Int
  changeType   String
  changedById  String
  previousData Json?
  newData      Json
  createdAt    DateTime @default(now())

  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@index([tenantId, taxYearId, entityType, entityId])
  @@map("tax_rule_versions")
}

model TaxOverride {
  id             String    @id @default(cuid())
  tenantId       String
  employeeId     String
  taxYearId      String
  overrideType   String
  originalValue  Decimal   @db.Decimal(15, 2)
  overrideValue  Decimal   @db.Decimal(15, 2)
  reason         String
  overriddenById String
  overriddenAt   DateTime  @default(now())
  expiresAt      DateTime?
  isActive       Boolean   @default(true)

  @@index([tenantId, employeeId, taxYearId])
  @@map("tax_overrides")
}

model TaxAuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId])
  @@map("tax_audit_logs")
}

// ─── Email Infrastructure (Module 22) ────────────────────────────────────────

enum EmailProviderType {
  SMTP
  SES
  SENDGRID
  MAILGUN
  POSTMARK
  MOCK
}

enum SmtpEncryption {
  SSL
  TLS
  STARTTLS
  NONE
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  BOUNCED
  CANCELLED
  SUPPRESSED
}

enum EmailTemplateStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum EmailSuppressionReason {
  HARD_BOUNCE
  INVALID_ADDRESS
  MANUAL
  SPAM_COMPLAINT
}

model EmailProviderConfig {
  id                String            @id @default(cuid())
  tenantId          String
  providerType      EmailProviderType @default(SMTP)
  name              String
  isActive          Boolean           @default(false)
  isDefault         Boolean           @default(false)
  dailySendingLimit Int?
  createdById       String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  smtpConfig SmtpConfig?
  testLogs   EmailTestLog[]

  @@index([tenantId])
  @@map("email_provider_configs")
}

model SmtpConfig {
  id                String         @id @default(cuid())
  tenantId          String
  providerId        String         @unique
  host              String
  port              Int
  encryption        SmtpEncryption @default(STARTTLS)
  username          String
  passwordEncrypted String
  fromEmail         String
  fromName          String
  replyTo           String?
  bounceEmail       String?
  testRecipient     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  provider EmailProviderConfig @relation(fields: [providerId], references: [id])

  @@index([tenantId])
  @@map("smtp_configs")
}

model EmailTemplate {
  id          String              @id @default(cuid())
  tenantId    String?
  templateKey String
  name        String
  subject     String
  bodyHtml    String              @db.Text
  bodyText    String?             @db.Text
  variables   Json                @default("[]")
  language    String              @default("en")
  module      String
  isMandatory Boolean             @default(false)
  status      EmailTemplateStatus @default(ACTIVE)
  version     Int                 @default(1)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  versions EmailTemplateVersion[]

  @@unique([tenantId, templateKey, language])
  @@index([tenantId, module])
  @@map("email_templates")
}

model EmailTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String?  @db.Text
  variables   Json
  changedById String?
  createdAt   DateTime @default(now())

  template EmailTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@map("email_template_versions")
}

model EmailQueue {
  id             String      @id @default(cuid())
  tenantId       String
  idempotencyKey String?     @unique
  to             String[]
  cc             String[]    @default([])
  bcc            String[]    @default([])
  subject        String
  bodyHtml       String      @db.Text
  bodyText       String?     @db.Text
  templateKey    String?
  templateVars   Json?
  module         String?
  relatedType    String?
  relatedId      String?
  providerId     String?
  isMandatory    Boolean     @default(false)
  priority       Int         @default(5)
  status         EmailStatus @default(QUEUED)
  scheduledAt    DateTime?
  processAfter   DateTime?
  retryCount     Int         @default(0)
  maxRetries     Int         @default(3)
  lastError      String?     @db.Text
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  deliveryLog EmailDeliveryLog?
  attachments EmailAttachment[]

  @@index([tenantId, status])
  @@index([tenantId, module])
  @@index([processAfter])
  @@map("email_queue")
}

model EmailDeliveryLog {
  id           String      @id @default(cuid())
  tenantId     String
  queueId      String      @unique
  to           String[]
  cc           String[]    @default([])
  subject      String
  templateKey  String?
  module       String?
  relatedType  String?
  relatedId    String?
  providerType String?
  providerId   String?
  status       EmailStatus
  errorMessage String?     @db.Text
  retryCount   Int         @default(0)
  messageId    String?
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  queue EmailQueue @relation(fields: [queueId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, module])
  @@index([tenantId, templateKey])
  @@map("email_delivery_logs")
}

model EmailPreference {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  announcements   Boolean  @default(true)
  recognition     Boolean  @default(true)
  surveys         Boolean  @default(true)
  reminders       Boolean  @default(true)
  digestEmails    Boolean  @default(true)
  digestFrequency String   @default("DAILY")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, employeeId])
  @@map("email_preferences")
}

model EmailSuppression {
  id             String                 @id @default(cuid())
  tenantId       String?
  email          String
  reason         EmailSuppressionReason
  note           String?
  suppressedById String?
  createdAt      DateTime               @default(now())

  @@unique([email])
  @@index([tenantId])
  @@map("email_suppressions")
}

model EmailAttachment {
  id           String    @id @default(cuid())
  queueId      String
  fileObjectId String?
  filename     String
  contentType  String
  sizeBytes    Int?
  isSecureLink Boolean   @default(false)
  secureUrl    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  queue EmailQueue @relation(fields: [queueId], references: [id])

  @@index([queueId])
  @@map("email_attachments")
}

model EmailEvent {
  id         String   @id @default(cuid())
  tenantId   String
  queueId    String?
  messageId  String?
  eventType  String
  email      String
  metadata   Json?
  occurredAt DateTime @default(now())

  @@index([tenantId, eventType])
  @@index([messageId])
  @@map("email_events")
}

model EmailTestLog {
  id         String   @id @default(cuid())
  tenantId   String
  providerId String
  recipient  String
  success    Boolean
  error      String?
  testedById String
  testedAt   DateTime @default(now())

  provider EmailProviderConfig @relation(fields: [providerId], references: [id])

  @@index([tenantId, providerId])
  @@map("email_test_logs")
}
